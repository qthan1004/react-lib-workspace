    "vite": "^7.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "^4.1.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "resolutions": {
    "vite": "^7.0.0"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
