    "@emotion/babel-plugin": "11.13.5",
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/react": "22.5.4",
    "@nx/storybook": "22.5.4",
    "@nx/vite": "22.5.4",
    "@nx/vitest": "22.5.4",
