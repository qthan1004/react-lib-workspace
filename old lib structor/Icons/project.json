{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/icon/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/icon",
        "tsConfig": "libs/icon/tsconfig.lib.json",
        "project": "libs/icon/package.json",
        "entryFile": "libs/icon/src/index.ts",
        "external": [
          "react/jsx-runtime",
          "@emotion/styled",
          "@emotion/react",
          "@dgtx/utils"
        ],
        "rollupConfig": "@nx/react/plugins/bundle-rollup",
        "compiler": "babel",
        "assets": [
          {
            "glob": "libs/icon/README.md",
            "input": ".",
            "output": "."
          },
          {
            "glob": "libs/icon/src/assets",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "libs/icon/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "coverage/libs/icon"
      ],
      "options": {
        "jestConfig": "libs/icon/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
